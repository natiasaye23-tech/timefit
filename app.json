{
  "expo": {
    "name": "timefit",
    "slug": "timefit",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.natiasaye23tech.timefit",
      "permissions": [
        "CAMERA",
        "PACKAGE_USAGE_STATS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
